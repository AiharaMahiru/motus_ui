# OpenAI-compatible provider configuration.
# Copy this file to `.env` for local development. Do not commit real secrets.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Firecrawl/web search integration.
# Some code paths also accept FIRECRAWL_API_KEY for compatibility.
FIRECRAWL_KEY=
FIRECRAWL_API_KEY=

# Optional backend mode. Supported values depend on the local deployment.
# APP_BACKEND_MODE=local

# Optional server binding examples.
# HOST=127.0.0.1
# PORT=8000
